{
	"name": "dnbazar",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "npm run build && wrangler pages dev .svelte-kit/cloudflare",
		"test": "npm run test:integration && npm run test:unit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:integration": "playwright test",
		"test:unit": "vitest",
		"deploy": "npm run build && wrangler pages deploy .svelte-kit/cloudflare",
		"db:generate": "drizzle-kit generate:sqlite --config=drizzle.config.ts",
		"db:drop": "drizzle-kit drop --config=drizzle.config.ts",
		"db:push": "drizzle-kit push:sqlite --config=drizzle.config.ts",
		"db:studio": "drizzle-kit studio",
		"build-cf-types": "wrangler types && mv worker-configuration.d.ts src/"
	},
	"dependencies": {
		"@internationalized/date": "^3.5.2",
		"@libsql/client": "^0.6.0",
		"@lucia-auth/adapter-drizzle": "^1.0.7",
		"@paypal/paypal-js": "^8.0.5",
		"@planetscale/database": "^1.16.0",
		"@upstash/redis": "^1.29.0",
		"arctic": "^1.5.0",
		"bits-ui": "^0.20.1",
		"clsx": "^2.1.0",
		"cmdk-sv": "^0.0.17",
		"drizzle-orm": "^0.30.4",
		"formsnap": "^1.0.0",
		"lucia": "^3.1.1",
		"lucide-svelte": "^0.368.0",
		"mode-watcher": "^0.3.0",
		"oslo": "^1.2.0",
		"resend": "^3.2.0",
		"svelte-sonner": "^0.3.22",
		"sveltekit-superforms": "^2.12.5",
		"tailwind-merge": "^2.2.2",
		"tailwind-variants": "^0.2.1",
		"unplugin-auto-import": "^0.17.5",
		"unplugin-icons": "^0.18.5",
		"zod": "^3.22.4"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20240320.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.2.1",
		"@iconify/json": "^2.2.200",
		"@playwright/test": "^1.28.1",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-cloudflare": "^4.2.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@types/eslint": "^8.56.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"autoprefixer": "^10.4.16",
		"drizzle-kit": "^0.20.14",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.35.1",
		"postcss": "^8.4.32",
		"postcss-load-config": "^5.0.2",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"prettier-plugin-tailwindcss": "^0.5.9",
		"svelte": "^4.2.7",
		"svelte-check": "^3.6.0",
		"svelte-headless-table": "^0.18.2",
		"tailwindcss": "^3.3.6",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^5.0.3",
		"vitest": "^1.2.0",
		"wrangler": "^3.37.0"
	}
}
